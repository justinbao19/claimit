{
  "name": "@claimit/cli",
  "version": "0.2.0",
  "type": "module",
  "bin": {
    "claimit": "./dist/index.js"
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts",
    "dev": "tsx watch src/index.ts",
    "start": "tsx src/index.ts",
    "test": "vitest run",
    "typecheck": "tsc --project tsconfig.json --noEmit"
  },
  "dependencies": {
    "@claimit/core": "workspace:*",
    "@claimit/mcp": "workspace:*",
    "commander": "latest"
  }
}
